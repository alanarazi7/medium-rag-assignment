{
  "functions": {
    "api/prompt.py": {
      "runtime": "python3.12",
      "maxDuration": 30
    },
    "api/stats.py": {
      "runtime": "python3.12",
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
